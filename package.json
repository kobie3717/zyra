{
  "name": "zyra",
  "version": "0.1.7",
  "private": false,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/index.ts",
    "start:prod": "node dist/index.js",
    "pm2:start": "npm run build && pm2 startOrRestart ecosystem.config.cjs --env production",
    "pm2:restart": "npm run build && pm2 restart ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop zyra",
    "pm2:delete": "pm2 delete zyra",
    "pm2:logs": "pm2 logs zyra",
    "pm2:save": "pm2 save",
    "pm2:startup": "pm2 startup",
    "db:init": "tsx src/core/db/init.ts",
    "db:verify": "tsx src/core/db/verify.ts",
    "db:delete-session": "tsx src/core/db/delete-session.ts",
    "db:backfill": "tsx src/core/db/backfill.ts",
    "db:nulls": "tsx src/core/db/null-report.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && vitest --run --typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "postinstall": "patch-package",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@kaikybrofc/logger-module": "^1.0.4",
    "@whiskeysockets/baileys": "github:WhiskeySockets/Baileys#8e5093c198de5c5c0230a76e8a7224f6006ebb2e",
    "baileys-antiban": "github:kobie3717/baileys-antiban#master",
    "dotenv": "^16.4.5",
    "link-preview-js": "^4.0.1",
    "mysql2": "^3.20.0",
    "pm2": "^6.0.14",
    "qrcode-terminal": "^0.12.0",
    "redis": "^4.6.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.13.5",
    "@types/qrcode-terminal": "^0.12.2",
    "eslint": "^9.0.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "vite": "8.0.5",
    "basic-ftp": "5.3.1",
    "libsignal": {
      "protobufjs": "7.5.5"
    },
    "@whiskeysockets/libsignal-node": {
      "protobufjs": "7.5.5"
    }
  }
}
